# PokeBid scripts - environment variables
# Copy to .env and fill in real values:  cp scripts/.env.example scripts/.env
# Load before running:  set -a; source scripts/.env; set +a; ./scripts/harvest_jp.sh

# JustTCG API key (paid plan for full harvest). https://justtcg.com
JUSTTCG_KEY=tcg_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase project
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...your-anon-key

# Optional tuning
# SLEEP_MS=1300                 # spacing between JustTCG calls (50/min plan)
# ONLY_SETS=""                  # space-separated set ids; empty = all 435
